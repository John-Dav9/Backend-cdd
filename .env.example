# ── Serveur ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URLS=https://cmciea-france.com,https://www.cmciea-france.com

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=

# ── Firebase Admin ───────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=cmcieafrance-cdd
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Mail (Brevo) ─────────────────────────────────────────────────────────────
BREVO_API_KEY=
MAIL_FROM=contact@cmciea-france.com

# ── IA Chat (Groq) ───────────────────────────────────────────────────────────
GROQ_API_KEY=
