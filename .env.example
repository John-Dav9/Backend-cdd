# Firebase Admin SDK
FIREBASE_PROJECT_ID=cmcieafrance-cdd
FIREBASE_CLIENT_EMAIL=your-service-account@cmcieafrance-cdd.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=cmcieafrance-cdd.appspot.com

# Resend (emails)
RESEND_API_KEY=re_xxxxxxxxxxxx
MAIL_FROM=noreply@cmciea-france.com
MAIL_ADMIN=admin@cmciea-france.com

# App
PORT=3000
FRONTEND_URL=https://cmciea-france.com
ADMIN_SECRET=change_this_secret

# Dev admin fallback (development only)
DEV_ADMIN_ENABLED=false
DEV_ADMIN_EMAIL=admin-dev@local.test
DEV_ADMIN_PASSWORD=dev-admin-1234
DEV_ADMIN_TOKEN=dev-admin-token-change-me
